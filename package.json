{
  "name": "bookweaver-gui",
  "version": "0.5.0",
  "description": "Project Gutenberg 书籍下载工具 - GUI 版本",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:backend && tsc && vite build && electron-builder",
    "build:frontend": "vite build",
    "build:backend": "python build_backend.py",
    "preview": "vite preview",
    "dev:backend": "cd backend && python -m uvicorn main:app --reload --port 8765",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "antd": "^5.15.0",
    "@ant-design/icons": "^5.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.1.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.13.0"
  },
  "author": "BookWeaver Team",
  "license": "MIT"
}